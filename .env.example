# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=                    # From @BotFather on Telegram
TELEGRAM_WEBHOOK_SECRET=               # 32+ char random hex (openssl rand -hex 32)

# AI API Keys (optional - only needed if using external models)
ANTHROPIC_API_KEY=                     # Claude API key (optional)
OPENAI_API_KEY=                        # OpenAI API key (optional)
GROQ_API_KEY=                          # Groq API key (optional)
MISTRAL_API_KEY=                       # Mistral API key (optional)
OPENROUTER_API_KEY=                    # OpenRouter universal fallback (optional)

# Application Settings
NODE_ENV=production                    # production or development
PORT=3000                              # Port for Express server
USE_POLLING=false                      # true for Raspberry Pi/no domain, false for webhooks
CONFIG_PATH=/data/config.json          # Path to config.json
DATABASE_URL=./data/secureclaw.db      # SQLite database path

# Logging
LOG_LEVEL=info                         # debug, info, warn, error
